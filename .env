# Application
NODE_ENV=development
LOG_LEVEL=debug

# Transactions Service
TRANSACTIONS_PORT=3001
TRANSACTIONS_DB_URL=postgresql://cashflow:cashflow123@postgres:5432/transactions
DATABASE_URL=postgresql://cashflow:cashflow123@localhost:5432/transactions

# Consolidation Service
CONSOLIDATION_PORT=3002
CONSOLIDATION_DB_URL=postgresql://cashflow:cashflow123@postgres:5432/consolidation
CONSOLIDATION_CRON=0 0 * * *

# Reporting Service
REPORTING_PORT=3003
REPORTING_DB_URL=postgresql://cashflow:cashflow123@postgres:5432/reporting

# PostgreSQL
POSTGRES_USER=cashflow
POSTGRES_PASSWORD=cashflow123
POSTGRES_DB=cashflow
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_VHOST=/
RABBITMQ_MANAGEMENT_PORT=15672

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
JAEGER_PORT=16686
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# Elasticsearch
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# Kibana
KIBANA_PORT=5601

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100