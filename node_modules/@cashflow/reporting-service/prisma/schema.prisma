// Reporting Service - Read Models Optimized for Queries
// This schema uses denormalized data for fast read operations

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client-reporting"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Read Model: Denormalized transaction data for fast queries
model TransactionReadModel {
  id              String   @id @default(uuid())
  categoryId      String
  categoryName    String
  type            String   // CREDIT or DEBIT
  amount          Decimal  @db.Decimal(15, 2)
  description     String?
  status          String   // PENDING, COMPLETED, CANCELLED
  cancelReason    String?
  transactionDate DateTime
  createdAt       DateTime
  updatedAt       DateTime
  
  // Optimized indexes for common queries
  @@index([transactionDate])
  @@index([type, transactionDate])
  @@index([status, transactionDate])
  @@index([categoryId, transactionDate])
  @@map("transaction_read_model")
}

// Read Model: Daily balance snapshots for fast balance queries
model DailyBalanceReadModel {
  id             String   @id @default(uuid())
  date           DateTime @db.Date @unique
  openingBalance Decimal  @db.Decimal(15, 2)
  totalCredits   Decimal  @db.Decimal(15, 2)
  totalDebits    Decimal  @db.Decimal(15, 2)
  closingBalance Decimal  @db.Decimal(15, 2)
  transactionCount Int
  createdAt      DateTime
  updatedAt      DateTime
  
  // Indexes
  @@index([date])
  @@map("daily_balance_read_model")
}

// Read Model: Aggregated statistics for dashboard
model SystemStatistics {
  id                    String   @id @default(uuid())
  currentBalance        Decimal  @db.Decimal(15, 2)
  totalCreditsMonth     Decimal  @db.Decimal(15, 2)
  totalDebitsMonth      Decimal  @db.Decimal(15, 2)
  totalTransactionsMonth Int
  averageTransactionValue Decimal @db.Decimal(15, 2)
  lastTransactionDate   DateTime?
  lastUpdated           DateTime
  
  @@map("system_statistics")
}

// Read Model: Category summary for analytics
model CategorySummary {
  id              String   @id @default(uuid())
  categoryId      String
  categoryName    String
  month           DateTime @db.Date
  totalCredits    Decimal  @db.Decimal(15, 2)
  totalDebits     Decimal  @db.Decimal(15, 2)
  transactionCount Int
  createdAt       DateTime
  updatedAt       DateTime
  
  @@unique([categoryId, month])
  @@index([month])
  @@index([categoryId, month])
  @@map("category_summary")
}