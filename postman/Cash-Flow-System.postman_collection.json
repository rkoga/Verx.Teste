        {
          "name": "Get Daily Balance",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const today = new Date().toISOString().split('T')[0];",
                  "pm.environment.set('current_date', today);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 404', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    pm.test('Response has balance details', function () {",
                  "        var jsonData = pm.response.json();",
                  "        pm.expect(jsonData).to.have.property('openingBalance');",
                  "        pm.expect(jsonData).to.have.property('closingBalance');",
                  "        pm.expect(jsonData).to.have.property('totalCredits');",
                  "        pm.expect(jsonData).to.have.property('totalDebits');",
